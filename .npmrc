# Força o pnpm a utilizar um diretório flat (hoisted), eliminando problemas com links simbólicos no ambiente de build da Vercel
node-linker=hoisted
# Evita que avisos de peer dependencies interrompam a instalação com erro exit code 1
strict-peer-dependencies=false
# Auto-instala peer dependencies ausentes de forma transparente
auto-install-peers=true
# Eleva todos os pacotes para a raiz do node_modules para evitar problemas de resolução profunda
shamefully-hoist=true